# ──────────────────────────────────────────────────────────────
# Estimo — variables d'environnement (copier vers .env, NE PAS committer .env)
# ──────────────────────────────────────────────────────────────

# --- Serveur ---
NODE_ENV=development            # development | production
HOST=0.0.0.0                    # 0.0.0.0 en conteneur/Railway
PORT=8080
LOG_LEVEL=info                  # fatal|error|warn|info|debug|trace
TENANTS_DIR=./tenants           # dossier des configs d'agences
RATE_LIMIT_MAX=30               # requêtes/min/IP sur l'API publique

# --- Secrets par agence (préfixe = id en MAJUSCULES) ---
# Agence "demo" (mail.provider=smtp dans tenants/demo.json) :
DEMO_SMTP_URL=smtps://utilisateur:motdepasse@smtp.exemple.com:465
# DEMO_PUBLIC_KEY=                # optionnel : clé publique attendue du widget
# DEMO_MAIL_API_KEY=             # si provider Brevo/SendGrid/Mailgun
# DEMO_CRM_API_KEY=              # si crm.provider = brevo|mailchimp

# Exemple d'une 2e agence "acme" en Brevo + Mailchimp :
# ACME_MAIL_API_KEY=xkeysib-...
# ACME_CRM_API_KEY=...-us21
