  "devDependencies": {
    "@types/node": "20.16.5",
    "@types/nodemailer": "6.4.16",
    "@types/pdfkit": "^0.17.6",
    "pino-pretty": "13.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
